{
  "rewrites": [
    { "source": "/solutions", "destination": "/solutions.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/what-is-an-ai-audit", "destination": "/blog/what-is-an-ai-audit.html" },
    { "source": "/blog/how-much-does-ai-consulting-cost", "destination": "/blog/how-much-does-ai-consulting-cost.html" },
    { "source": "/blog/5-signs-your-business-is-ready-for-ai", "destination": "/blog/5-signs-your-business-is-ready-for-ai.html" },
    { "source": "/blog/what-to-expect-from-an-ai-audit", "destination": "/blog/what-to-expect-from-an-ai-audit.html" },
    { "source": "/blog/roi-of-ai-automation-for-small-businesses", "destination": "/blog/roi-of-ai-automation-for-small-businesses.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://portal.talosops.ai https://www.google-analytics.com; frame-ancestors 'none'" }
      ]
    }
  ]
}
